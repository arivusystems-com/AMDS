# Copy to .env for local development
# cp .env.example .env

AMDS_PORT=8080
NODE_ENV=development

# Docker Compose services (docker compose up -d)
DATABASE_URL=postgresql://amds:amds@localhost:5432/amds
REDIS_URL=redis://localhost:6379

# Local SMTP — Mailpit (no real delivery, no port 25)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false

# Auth
AMDS_API_KEY=amds_dev_key
WEBHOOK_SIGNING_SECRET=dev_webhook_secret

# LiteDesk webhook target (AMDS worker posts delivery events here)
LITEDESK_WEBHOOK_URL=http://localhost:3000/api/internal/webhooks/amds

# Default sender for local testing
DEFAULT_FROM_EMAIL=noreply@localhost.test
DEFAULT_FROM_NAME=AMDS Local
